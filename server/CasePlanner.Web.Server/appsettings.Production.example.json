{
  "Hosting": {
    "Urls": "https://caseplanner.example.gov:443"
  },
  "Database": {
    "ActiveProvider": "Sqlite",
    "CommandTimeoutSeconds": 30,
    "SqlServerPilotWritesEnabled": false
  },
  "ConnectionStrings": {
    "CasePlannerSqlServer": "SUPPLY_FROM_DEPLOYMENT_SECRET_STORE"
  },
  "DocumentStorage": {
    "Provider": "FileSystem",
    "RootPath": "\\\\approved-file-server\\CasePlannerDocuments"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "00000000-0000-0000-0000-000000000000",
    "ClientId": "00000000-0000-0000-0000-000000000000"
  },
  "Authentication": {
    "Entra": {
      "Enabled": false,
      "SpaClientId": "00000000-0000-0000-0000-000000000000",
      "ApiScope": "CasePlanner.Access",
      "RequiredAppRole": "CasePlanner.User",
      "AdministratorAppRole": "CasePlanner.Admin",
      "AdministratorPilotOnly": true
    }
  },
  "AllowedHosts": "caseplanner.example.gov"
}
