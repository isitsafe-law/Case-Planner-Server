{
  "Hosting": {
    "Urls": "https://caseplanner.example.gov:443"
  },
  "Database": {
    "ActiveProvider": "SqlServer",
    "CommandTimeoutSeconds": 30,
    "SqlServerPilotWritesEnabled": false
  },
  "ConnectionStrings": {
    "CasePlannerSqlServer": "SUPPLY_FROM_SECRET_STORE"
  },
  "DocumentStorage": {
    "Provider": "FileSystem",
    "RootPath": "\\\\approved-file-server\\CasePlannerDocuments"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "SUPPLY_FROM_SECRET_STORE",
    "ClientId": "SUPPLY_FROM_SECRET_STORE"
  },
  "Authentication": {
    "Entra": {
      "Enabled": true,
      "SpaClientId": "SUPPLY_FROM_SECRET_STORE",
      "ApiScope": "CasePlanner.Access",
      "RequiredAppRole": "CasePlanner.User",
      "AdministratorAppRole": "CasePlanner.Admin",
      "AdministratorPilotOnly": false
    }
  },
  "AllowedHosts": "caseplanner.example.gov"
}
