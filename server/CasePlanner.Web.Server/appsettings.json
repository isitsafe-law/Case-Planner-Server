{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Hosting": {
    "Urls": "http://127.0.0.1:5188"
  },
  "Database": {
    "ActiveProvider": "Sqlite",
    "CommandTimeoutSeconds": 30,
    "SqlServerPilotWritesEnabled": false
  },
  "DocumentStorage": {
    "Provider": "FileSystem",
    "RootPath": ""
  },
  "ConnectionStrings": {
    "CasePlannerSqlServer": ""
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": ""
  },
  "Authentication": {
    "Entra": {
      "Enabled": false,
      "SpaClientId": "",
      "ApiScope": "CasePlanner.Access",
      "RequiredAppRole": "",
      "AdministratorAppRole": "CasePlanner.Admin",
      "AdministratorPilotOnly": true
    }
  },
  "AllowedHosts": "*"
}
